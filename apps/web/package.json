{
  "name": "@lab/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node scripts/copy-pdf-worker.mjs && vite --host 0.0.0.0",
    "copy:pdf-worker": "node scripts/copy-pdf-worker.mjs",
    "build": "node scripts/copy-pdf-worker.mjs && tsc -p tsconfig.json && vite build",
    "build:web": "node scripts/copy-pdf-worker.mjs && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "mammoth": "^1.10.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2"
  }
}
